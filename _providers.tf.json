{
  "terraform": {
    "required_version": ">= 1.10.5",
    "required_providers": {
      "github": {
        "source": "integrations/github",
        "version": "6.12.1"
      },
      "vault": {
        "source": "hashicorp/vault",
        "version": "5.6.0"
      }
    },
    "backend": {
      "http": {}
    }
  },
  "provider": {
    "github": {
      "owner": "dev-rachuna",
      "token": "${data.vault_generic_secret.auth_github.data[\"GITHUB_TOKEN\"]}"
    },
    "vault": {
      "skip_tls_verify": true
    }
  }
}
